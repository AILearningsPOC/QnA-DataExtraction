# ─── Required ────────────────────────────────────────────
PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ─── AI (optional — enables language detection, RAG, sentiment) ──
